{
  "expo": {
    "name": "Amal",
    "slug": "amal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#faf5ff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.amal.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#faf5ff"
      },
      "package": "com.amal.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-localization",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Amal to record audio to document incidents for your safety."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Amal to capture your GPS coordinates during recording."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
